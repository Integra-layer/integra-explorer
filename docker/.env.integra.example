# Integra Explorer — Environment Variables
# Copy this file to .env.integra and fill in real values
#
# Generate secrets:
#   openssl rand -hex 16  (32-char hex string)
#   openssl rand -hex 32  (64-char hex string)
#   openssl rand -base64 32 | tr -dc 'a-zA-Z0-9' | head -c 32  (alphanumeric)
#   openssl rand -base64 64 | sed 's/"/\\"/g'  (base64 for Firebase keys)

# --- Database ---
DB_PASSWORD=CHANGE_ME_32_CHAR_HEX

# --- Encryption & Secrets ---
ENCRYPTION_KEY=CHANGE_ME_32_CHAR_HEX
ENCRYPTION_JWT_SECRET=CHANGE_ME_64_CHAR_HEX
SECRET=CHANGE_ME_32_CHAR_ALPHANUMERIC
AUTH_SECRET=CHANGE_ME_64_CHAR_HEX

# --- Soketi (WebSocket) ---
SOKETI_KEY=CHANGE_ME_app_key
SOKETI_SECRET=CHANGE_ME_32_CHAR_ALPHANUMERIC

# --- Firebase Auth (self-hosted) ---
FIREBASE_SIGNER_KEY=CHANGE_ME_BASE64_64
FIREBASE_SALT_SEPARATOR=CHANGE_ME_BASE64_16

# --- PM2 Server (block sync process manager) ---
PM2_SECRET=CHANGE_ME_32_CHAR_HEX

# --- App ---
# APP_DOMAIN = admin/login URL (must differ from public explorer domain)
# Public explorer domain is set in the explorer_domains DB table
APP_DOMAIN=admin.testnet.explorer.integralayer.com
APP_URL=admin.testnet.explorer.integralayer.com

# --- Bull Board (optional, defaults shown) ---
BULLBOARD_USERNAME=ethernal
BULLBOARD_PASSWORD=CHANGE_ME_16_CHAR_ALPHANUMERIC
