# Integra Explorer Frontend — Environment Variables
# Copy to .env.local and fill in values.
# WARNING: All NEXT_PUBLIC_* variables are baked into the JS bundle at build time.
# In Docker, pass these as --build-arg during docker build.

# Network mode: "testnet" | "mainnet"
# Controls whether the testnet badge is displayed in the UI.
NEXT_PUBLIC_NETWORK_MODE=testnet

# API base path for Ethernal backend
# Typically proxied by Caddy or nginx from /api/* to the Ethernal server.
# Leave as /api for production (reverse proxy handles routing).
NEXT_PUBLIC_API_URL=/api

# Workspace name in Ethernal (must match exactly, NOT the numeric workspace ID)
# Example: "Integra Testnet" or "Integra Mainnet"
# If this doesn't match the actual workspace, API calls will fail.
NEXT_PUBLIC_WORKSPACE_ID=Integra Testnet

# Soketi / Pusher configuration for real-time block and transaction updates
# If NEXT_PUBLIC_PUSHER_KEY is empty, real-time updates are disabled.
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_HOST=testnet.explorer.integralayer.com
NEXT_PUBLIC_PUSHER_PORT=6002

# Cosmos REST API endpoint for validators and governance proposals
# Used for /cosmos/staking/v1beta1/validators and /cosmos/gov/v1/proposals
NEXT_PUBLIC_COSMOS_API_URL=https://testnet.integralayer.com/api

# Full site URL (used for SSR API calls and social sharing)
# Must include protocol and hostname, no trailing slash.
NEXT_PUBLIC_SITE_URL=https://testnet.explorer.integralayer.com

# Reown (WalletConnect) project ID for wallet connection modal
# Get one at https://cloud.reown.com (formerly cloud.walletconnect.com)
NEXT_PUBLIC_REOWN_PROJECT_ID=

# EVM JSON-RPC endpoint for direct blockchain queries (balance, contract reads)
# Used by wagmi/viem for on-chain data fetching.
NEXT_PUBLIC_EVM_RPC_URL=https://testnet.integralayer.com/evm

# Faucet API endpoint (used by the /faucet page to request testnet tokens)
# Defaults to /api/faucet (relative, handled by reverse proxy) if not set.
NEXT_PUBLIC_FAUCET_API_URL=/api/faucet

# Blockscout explorer URL (used for "View Transaction" links after faucet drip)
# Defaults to https://testnet.blockscout.integralayer.com if not set.
NEXT_PUBLIC_BLOCKSCOUT_URL=https://testnet.blockscout.integralayer.com
