# PM2 Server — Environment Variables
# Copy to .env and fill in values.
# SECRET must match run/.env PM2_SECRET.

SECRET=CHANGE_ME_MUST_MATCH_RUN_PM2_SECRET
ETHERNAL_HOST=http://localhost:8888
ETHERNAL_SECRET=CHANGE_ME_MUST_MATCH_RUN_SECRET

# Redis (for BullMQ; optional if pm2-server doesn't use queues)
ETHERNAL_REDIS_URL=redis://localhost:6379

# Port (default 9090)
PORT=9090
